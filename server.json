{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Agentled/mcp-server",
  "description": "AI workflow orchestration with 100+ integrations, knowledge graph, and unified credits.",
  "repository": {
    "url": "https://github.com/Agentled/mcp-server",
    "source": "github"
  },
  "version": "0.5.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@agentled/mcp-server",
      "version": "0.5.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "AGENTLED_API_KEY",
          "description": "Your AgentLed workspace API key (generate in Workspace Settings > Developer)",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "AGENTLED_URL",
          "description": "AgentLed instance URL (default: https://www.agentled.app)",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
